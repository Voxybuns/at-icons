[sub_resource type="GDScript" id="GDScript_54k6s"]
resource_name = "IconGrid"
script/source = "@tool
extends HFlowContainer

@export var width := 48
@export var height := 24
@export var corner_size := 4
@export var icon_dimensions := Vector2(16, 16)

@export var dark_bg_col := Color(\"292929\")
@export var light_bg_col := Color(\"e5e5e5\")

const COLORS: Dictionary[String, Dictionary] = {
	\"Node\":{
		\"dark\": Color(\"e0e0e0\"),
		\"light\": Color(\"5a5a5a\"),
	},
	\"Node2D\":{
		\"dark\": Color(\"8da5f3\"),
		\"light\": Color(\"3d64dd\"),
	},
	\"Node3D\":{
		\"dark\": Color(\"fc7f7f\"),
		\"light\": Color(\"cd3838\"),
	},
	\"Control\":{
		\"dark\": Color(\"8eef97\"),
		\"light\": Color(\"2fa139\"),
	},
}


var editor_scale : float

var selected_type: String:
	get:
		return icon_type_button.get_item_text(icon_type_button.get_selected_id())

var selected_lang: String:
	get:
		return declaration_type_button.get_item_text(declaration_type_button.get_selected_id())

## Make sure that the node type here is node3d because it's hardcoded to assume node3d
@export var icons_directory := \"res://addons/at-icons/node3d/\" 
#@export var icon_white_shader_mat : ShaderMaterial
@export var icon_shader: Shader

@export var json_holder: Node

@export var icon_type_button: OptionButton:
	set(value):
		if icon_type_button and icon_type_button.item_selected.is_connected(update):
			icon_type_button.item_selected.disconnect(update)
		icon_type_button = value
		icon_type_button.item_selected.connect(update.unbind(1))
		update()
		
@export var declaration_type_button: OptionButton

#@export_tool_button(\"Update\") var _update = update

var _button_theme: Theme = Theme.new()


var light_mat := ShaderMaterial.new()
var dark_mat := ShaderMaterial.new()


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	if Engine.is_editor_hint():
		editor_scale = EditorInterface.get_editor_scale()
	else:
		editor_scale = 1.0
	light_mat.shader = icon_shader
	dark_mat.shader = icon_shader
	var ticks := Time.get_ticks_usec()
	_initialize_nodes()
	var took := Time.get_ticks_usec() - ticks
	prints(\"It took exactly\", took / 1_000_000.0, \"seconds to create all the buttons.\")
	update()


func _update_button_theme() -> void:
	_button_theme = Theme.new()
	
	var button_clip_stylebox := StyleBoxFlat.new()
	button_clip_stylebox.corner_radius_bottom_left = corner_size
	button_clip_stylebox.corner_radius_bottom_right = corner_size
	button_clip_stylebox.corner_radius_top_left = corner_size
	button_clip_stylebox.corner_radius_top_right = corner_size
	
	for state in [\"normal\", \"hover\", \"pressed\", \"hover_pressed\"]:
		_button_theme.set_stylebox(state, \"Button\", button_clip_stylebox)

@export_storage var icons : Array[Texture2D]

#var buttons: Dictionary[String, Array]


func update() -> void:
	light_mat.set_shader_parameter(\"requested_color\", COLORS[selected_type][\"light\"])
	dark_mat.set_shader_parameter(\"requested_color\", COLORS[selected_type][\"dark\"])


@export_tool_button(\"Recreate Buttons\") var _init_nodes_tool := _initialize_nodes
func _initialize_nodes() -> void:
	_update_button_theme()
	var dark_bg_style := StyleBoxFlat.new()
	dark_bg_style.bg_color = dark_bg_col
	var light_bg_style := StyleBoxFlat.new()
	light_bg_style.bg_color = light_bg_col
	
	## The light mode icon is darker than the dark mode icon.
	#var light_mat := ShaderMaterial.new()
	#light_mat.shader = icon_shader
	#light_mat.set_shader_parameter(\"requested_color\", COLORS[type][\"light\"])
	#
	#var dark_mat := ShaderMaterial.new()
	#dark_mat.shader = icon_shader
	#dark_mat.set_shader_parameter(\"requested_color\", COLORS[type][\"dark\"])
	
	_remove_all_children()
	
	#var last_c_cont : CenterContainer
	#update_icon_list()
	
	for texture in icons:
			var button := Button.new()
			button.clip_children = CanvasItem.CLIP_CHILDREN_ONLY
			button.theme = _button_theme
			button.custom_minimum_size = Vector2(width, height) * editor_scale
			button.size = button.custom_minimum_size
			button.mouse_default_cursor_shape = Control.CURSOR_POINTING_HAND
			button.tooltip_text = texture.resource_path.get_file()
			
			
			var hbox := HBoxContainer.new()
			hbox.add_theme_constant_override(\"separation\", 0)
			hbox.mouse_behavior_recursive = Control.MOUSE_BEHAVIOR_DISABLED
			hbox.position = Vector2()
			hbox.size = button.size
			
			#region Dark
			var panel_d := Panel.new()
			panel_d.add_theme_stylebox_override(\"panel\", dark_bg_style)
			panel_d.size_flags_horizontal = Control.SIZE_EXPAND_FILL
			panel_d.size_flags_vertical = Control.SIZE_EXPAND_FILL
			
			var trect_d := TextureRect.new()
			trect_d.texture = texture
			trect_d.material = dark_mat
			trect_d.custom_minimum_size = icon_dimensions
			trect_d.size_flags_horizontal = Control.SIZE_SHRINK_CENTER
			trect_d.size_flags_vertical = Control.SIZE_SHRINK_CENTER
			
			#var c_cont_d := CenterContainer.new()
			#c_cont_d.size = panel_d.size
			#c_cont_d.position = Vector2()
			
			#c_cont_d.add_child(trect_d)
			panel_d.add_child(trect_d)
			trect_d.anchor_bottom = 0.5
			trect_d.offset_bottom = icon_dimensions.y / 2 * editor_scale
			trect_d.anchor_top = 0.5
			trect_d.offset_top = icon_dimensions.y / -2 * editor_scale
			trect_d.anchor_right = 0.5
			trect_d.offset_right = icon_dimensions.x / 2 * editor_scale
			trect_d.anchor_left = 0.5
			trect_d.offset_left = icon_dimensions.x / -2 * editor_scale
			
			hbox.add_child(panel_d)
			
			#c_cont_d.queue_sort()
			#endregion
			
			#region Dark
			var panel_l := Panel.new()
			panel_l.add_theme_stylebox_override(\"panel\", light_bg_style)
			panel_l.size_flags_horizontal = Control.SIZE_EXPAND_FILL
			panel_l.size_flags_vertical = Control.SIZE_EXPAND_FILL
			
			var trect_l := TextureRect.new()
			trect_l.texture = texture
			trect_l.material = light_mat
			trect_l.custom_minimum_size = icon_dimensions
			trect_l.size_flags_horizontal = Control.SIZE_SHRINK_CENTER
			trect_l.size_flags_vertical = Control.SIZE_SHRINK_CENTER
			
			#var c_cont_l := CenterContainer.new()
			#c_cont_l.size = panel_l.size
			#c_cont_l.position = Vector2()
			
			#c_cont_l.add_child(trect_l)
			panel_l.add_child(trect_l)
			trect_l.anchor_bottom = 0.5
			trect_l.offset_bottom = icon_dimensions.y / 2 * editor_scale
			trect_l.anchor_top = 0.5
			trect_l.offset_top = icon_dimensions.y / -2 * editor_scale 
			trect_l.anchor_right = 0.5
			trect_l.offset_right = icon_dimensions.x / 2 * editor_scale
			trect_l.anchor_left = 0.5
			trect_l.offset_left = icon_dimensions.x / -2 * editor_scale
			
			hbox.add_child(panel_l)
			
			#c_cont_l.queue_sort()
			#endregion
			
			#last_c_cont = c_cont_l
			
			#var ticks0 := Time.get_ticks_usec()
			
			##region Label
			#var label := Label.new()
			#label.grow_horizontal = Control.GROW_DIRECTION_BOTH
			#label.grow_vertical = Control.GROW_DIRECTION_BOTH
			#label.set_anchors_and_offsets_preset(Control.PRESET_CENTER_BOTTOM)
			#var text := texture.resource_path.get_file()
			#label.add_theme_font_size_override(\"font_size\", 12)
			#label.add_theme_color_override(\"font_color\", Color.BLACK)
			#label.text = text
			#label.z_index = 1
			#
			##var t1 := Time.get_ticks_usec()
			##var p1_took := t1 - ticks0
			#
			#var label_style := StyleBoxFlat.new()
			#label_style.bg_color = Color(1.0, 0.851, 0.0, 1.0) # Eyedropped color
			#label_style.set_corner_radius_all(10)
			#label_style.set_content_margin_all(10)
			#label.add_theme_stylebox_override(\"normal\", label_style)
			##endregion
			
			#var t2 := Time.get_ticks_usec()
			#var p2_took := t2 - t1
			
			button.add_child(hbox)
			#button.add_child(label)
			button.name = texture.resource_path.get_file().get_basename()
			self.add_child(button)
			
			#var t3 := Time.get_ticks_usec()
			#var p3_took := t3 - t2
			
			#label.position.y += 13
			#label.hide()
			
			#button.pressed.connect(
				#copy_icon_to_clipboard.bind(
					#texture.resource_path.replace(
						#\"node3d\", 
						#type.to_lower()
			#)))
			
			button.pressed.connect(func():
				copy_icon_to_clipboard(
					texture.resource_path.replace(
						\"node3d\", 
						selected_type.to_lower()
			)))
			
			#button.mouse_entered.connect(label.show)
			#button.mouse_exited.connect(label.hide)
			#var t4 := Time.get_ticks_usec()
			#var p4_took := t4 - t3
			
			# Profiling. This usually triggers a lag spike.
			#print_debug([p1_took, p2_took, p3_took, p4_took])
			
			#print(texture.resource_name)
			#var array : Array = buttons.get_or_add(type, [])
			
			#array.append(button)
			#button.visible = not hide_btns
		
		#last_c_cont.queue_sort()
	
	#print_tree_pretty()


@export_tool_button(\"Update Icon List\") var _update_icons := update_icon_list

@export_tool_button(\"Delete all buttons\") var _remove_buttons_tool := _remove_all_children
## Might decrease lag.
func _remove_all_children() -> void:
	for child in get_children():
		child.queue_free()


func update_icon_list() -> void:
	#region Directory
	var dir = DirAccess.open(icons_directory)
	if dir:
		dir.list_dir_begin()
		var file_name = dir.get_next()
		while file_name != \"\":
			if dir.current_is_dir():
				#print(\"Found directory: \" + file_name)
				file_name = dir.get_next()
				continue
			#else:
			print(\"Found file: \" + file_name)
			if file_name.ends_with(\".import\"):
				print(\"Ignoring file \" + file_name + \" because it is an import file.\")
				file_name = dir.get_next()
				continue
			var file := load(dir.get_current_dir() + \"/\" + file_name)
			if file is not Texture2D:
				push_error(\"File %s in directory is not a Texture2D resource.\" % [file_name])
				file_name = dir.get_next()
				continue
			var texture := file as Texture2D
			#endregion
			icons.append(texture)
			#texture.resource_name = file_name
			file_name = dir.get_next()
	else:
		push_error(\"An error occurred when trying to access icon path at %s\" % [icons_directory])


## Copies the string to the clipboard.
func copy_icon_to_clipboard(filepath: String) -> void:
	# Get the current contents of the clipboard
	#var current_clipboard = DisplayServer.clipboard_get()
	# Set the contents of the clipboard
	var string: String
	
	match selected_lang:
		\"GDScript\":
			string = \"@icon(\\\"%s\\\")\" % [filepath]
		\"C#\":
			string = \"[GlobalClass, Icon(\\\"%s\\\")]\" % [filepath]
	
	DisplayServer.clipboard_set(string)


## We need this to do the keyword search 
@onready var json: Node = %JSON


func search(text: String) -> void:
	if not text: # No query:
		for child in get_children():
			child.show()
		return
	
	text = text.replace(\" \", \"_\")
	
	var search_aliases: Dictionary[String, Array] = json_holder.search_aliases
	# There is a query
	for child in get_children():
		child.visible = false
		var icon_aliases: Array
		if child.name not in search_aliases:
			icon_aliases = [child.name]
		else:
			icon_aliases = search_aliases[child.name]
		for alias: String in icon_aliases:
			if text in alias:
				child.show()
				break # if one alias has it, don't bother with the others
"

[sub_resource type="Shader" id="Shader_8e00h"]
code = "shader_type canvas_item;

void vertex() {
	// Called for every vertex the material is visible on.
}

uniform vec3 requested_color;

void fragment() {
	COLOR.r = requested_color.r;
	COLOR.g = requested_color.g;
	COLOR.b = requested_color.b;
}

//void light() {
//	// Called for every pixel for every light affecting the CanvasItem.
//	// Uncomment to replace the default light processing function with this one.
//}
"

[sub_resource type="GDScript" id="GDScript_6a224"]
resource_name = "json_holder"
script/source = "@tool
extends Node

## Here, you should put the [code]icons.json[/code] file contents, found at 
## [code]at-icons/site_src/_data/icons.json[/code] in the raw repo.
## If that file is updated, update it here too. 
@export_multiline() var json_string : String

## The cached search aliases. Use [code]update_search_aliases()[/code] to update them
@onready var search_aliases: Dictionary[String, Array]

func _get_raw_data() -> Dictionary:
	return JSON.parse_string(json_string)


func _csv_to_array(csv: String) -> PackedStringArray:
	return csv.split(\", \")


## Turns icon data into a Dictionary[filename: String, aliases: Array[String]] format.
## The aliases include the original file name.
func _get_search_aliases(data := _get_raw_data()) -> Dictionary[String, Array]:
	var aliases: Dictionary[String, Array] = {}
	for icon: String in data:
		aliases[icon] = _csv_to_array(data[icon].description)
		aliases[icon].append(icon)
	
	return aliases

func update_search_aliases() -> void:
	search_aliases = _get_search_aliases()


func _ready() -> void:
	update_search_aliases()
"

